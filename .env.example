# Copy this file to .env and fill in your values.
# Never commit .env to version control.

THUNDER_NUM_PARALLEL_REQUESTS=8
THUNDER_AUTH_TYPE=Bearer
THUNDER_AUTH_TOKEN=access_token
THUNDER_AUTH_URL=https://your-auth-server.example.com/oauth/token
THUNDER_AUTH_GRANT_TYPE=client_credentials
THUNDER_AUTH_CLIENT_ID=your-client-id
THUNDER_AUTH_SCOPE=openid
THUNDER_AUTH_CLIENT_SECRET=your-client-secret
THUNDER_AUTH_VENDOR_ID=your-vendor-id
